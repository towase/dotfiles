{
  "permissions": {
    "allow": [
      "WebSearch",
      "Bash(git commit *)",
      "Bash(git push *)",
      "Bash(open /tmp/*)"
    ],
    "defaultMode": "auto"
  },
  "enabledPlugins": {
    "typescript-lsp@claude-plugins-official": true
  },
  "language": "",
  "skipAutoPermissionPrompt": true,
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh"
  }
}
